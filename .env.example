# ── LLM Provider ──────────────────────────────────────────────────────
# Options: ollama | claude | openai | gemini
# Default: ollama (no API key needed — uses local Ollama)
LLM_PROVIDER=ollama

# ── Ollama (local — no API key needed) ────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
# LLM model — must be pulled first: ollama pull llama3.2
OLLAMA_MODEL=llama3.2
# Embedding model — must be pulled first: ollama pull nomic-embed-text
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── Embedding Provider ─────────────────────────────────────────────────
# Options: ollama | huggingface
# ollama  → uses OLLAMA_EMBED_MODEL via Ollama API (no extra install)
# huggingface → uses sentence-transformers/all-MiniLM-L6-v2 (needs pip install sentence-transformers)
EMBED_PROVIDER=ollama

# ── Cloud LLM Providers (optional — only needed if not using Ollama) ──
# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
# OpenAI
OPENAI_API_KEY=sk-...
# Google
GOOGLE_API_KEY=AIza...

# ── Database ──────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///data/ruralcare.db

# ── Vector Store ──────────────────────────────────────────────────────
CHROMA_DB_PATH=data/chroma

# ── RAG ───────────────────────────────────────────────────────────────
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.55

# ── Translation ───────────────────────────────────────────────────────
GOOGLE_TRANSLATE_API_KEY=

# ── Maps ──────────────────────────────────────────────────────────────
NOMINATIM_USER_AGENT=ruralcare-ai/0.1.0

# ── Emergency Webhook (optional) ──────────────────────────────────────
EMERGENCY_WEBHOOK_URL=

# ── LangSmith Tracing (optional) ──────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=ruralcare-ai

# ── App Settings ──────────────────────────────────────────────────────
DEMO_MODE=true
MAX_INPUT_LENGTH=2000
LOG_LEVEL=INFO
